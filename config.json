{
  "providers": {
    "openai": {
      "api_key": "${OPENAI_API_KEY}",
      "models": {
        "gpt-4": {
          "preferred_for": ["complex analysis", "multi-file PRs"]
        },
        "gpt-3.5-turbo": {
          "preferred_for": ["standard PRs", "quick analysis"]
        }
      }
    },
    "anthropic": {
      "api_key": "${ANTHROPIC_API_KEY}",
      "models": {
        "claude-3-opus": {
          "preferred_for": ["complex analysis", "deep understanding"]
        },
        "claude-3-sonnet": {
          "preferred_for": ["standard PRs", "balanced performance"]
        },
        "claude-3-haiku": {
          "preferred_for": ["quick analysis", "simple changes"]
        }
      }
    },
    "gemini": {
      "api_key": "${GEMINI_API_KEY}",
      "models": {
        "gemini-pro": {
          "preferred_for": ["standard PRs", "code analysis"]
        }
      }
    }
  },
  "default_provider": "openai",
  "default_model": "gpt-4",
  "fallback_strategy": "downgrade_model"
}
