{
  "name": "generate-pr-mcp",
  "version": "1.1.1",
  "description": "AI-powered Model Context Protocol server for intelligent PR generation with advanced code analysis",
  "type": "module",
  "bin": {
    "mcp-server": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.6.0",
    "vscode-uri": "^3.1.0",
    "zod": "^3.25.63"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "mcp",
    "pr",
    "pull-request",
    "generator",
    "ai",
    "artificial-intelligence",
    "code-analysis",
    "llm",
    "openai",
    "anthropic",
    "prompt-template",
    "git-diff",
    "automation"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kpndevroot/generate-pr-mcp.git"
  }
}
